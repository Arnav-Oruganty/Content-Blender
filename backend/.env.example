# ─── Server ───────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────
# Local:   mongodb://localhost:27017/content_blender
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/content_blender
MONGO_URI=mongodb://localhost:27017/content_blender

# ─── Storage backend ──────────────────────────────────
# "mongo"  → persist in MongoDB (production recommended)
# "file"   → persist as XML files in ./storage/  (dev/demo)
STORAGE_BACKEND=file

# ─── CORS ─────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
