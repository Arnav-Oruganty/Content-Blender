# ─── Server ───────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Storage backend ──────────────────────────────────
# File-based XML storage (file) or Native XML DB (basex)
STORAGE_BACKEND=file

BASEX_HOST=127.0.0.1
BASEX_PORT=1984
BASEX_USER=admin
BASEX_PASSWORD=admin

# ─── CORS ─────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
